@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ont: <http://www.semanticweb.org/antoi/ontologies/2026/2/audiovisual-ontology#> .
@prefix res: <http://www.semanticweb.org/antoi/data/resource/> .

# =================================================================
# 1. REFERENCE CLASSES (Dictionaries)
# =================================================================

<#MapCategory> a rr:TriplesMap;
    rr:logicalTable [ rr:tableName "category" ];
    rr:subjectMap [
        rr:template "http://www.semanticweb.org/antoi/data/resource/category/{category_id}";
        rr:class ont:Category
    ];
    rr:predicateObjectMap [
        rr:predicate ont:categoryName;        # OWL: #categoryName
        rr:objectMap [ rr:column "category_name" ]
    ] .

<#MapRole> a rr:TriplesMap;
    rr:logicalTable [ rr:tableName "role" ];
    rr:subjectMap [
        rr:template "http://www.semanticweb.org/antoi/data/resource/role/{role_id}";
        rr:class ont:Role
    ];
    rr:predicateObjectMap [
        rr:predicate ont:roleName;            # OWL: #roleName ✓
        rr:objectMap [ rr:column "role_name" ]
    ] .

<#MapGenre> a rr:TriplesMap;
    rr:logicalTable [ rr:tableName "genre" ];
    rr:subjectMap [
        rr:template "http://www.semanticweb.org/antoi/data/resource/genre/{genre_id}";
        rr:class ont:Genre
    ];
    rr:predicateObjectMap [
        rr:predicate ont:genreName;           # OWL: #genreName ✓
        rr:objectMap [ rr:column "genre_name" ]
    ] .

<#MapTitleType> a rr:TriplesMap;
    rr:logicalTable [ rr:tableName "title_type" ];
    rr:subjectMap [
        rr:template "http://www.semanticweb.org/antoi/data/resource/titleType/{title_type_id}";
        rr:class ont:TitleType
    ];
    rr:predicateObjectMap [
        rr:predicate ont:title_type_name;     # OWL: #title_type_name (snake_case — was ont:titleTypeName before, WRONG)
        rr:objectMap [ rr:column "title_type_name" ]
    ] .

<#MapContentType> a rr:TriplesMap;
    rr:logicalTable [ rr:tableName "content_type" ];
    rr:subjectMap [
        rr:template "http://www.semanticweb.org/antoi/data/resource/contentType/{content_type_id}";
        rr:class ont:ContentType
    ];
    rr:predicateObjectMap [
        rr:predicate ont:content_type_name;   # OWL: #content_type_name (snake_case — was ont:contentTypeName before, WRONG)
        rr:objectMap [ rr:column "content_type_name" ]
    ] .

<#MapRegion> a rr:TriplesMap;
    rr:logicalTable [ rr:tableName "region" ];
    rr:subjectMap [
        rr:template "http://www.semanticweb.org/antoi/data/resource/region/{region_id}";
        rr:class ont:Region
    ];
    rr:predicateObjectMap [
        rr:predicate ont:regionName;          # OWL: #regionName ✓
        rr:objectMap [ rr:column "region_name" ]
    ] .

<#MapLanguage> a rr:TriplesMap;
    rr:logicalTable [ rr:tableName "language" ];
    rr:subjectMap [
        rr:template "http://www.semanticweb.org/antoi/data/resource/language/{language_id}";
        rr:class ont:Language
    ] .
    # Note: ont:Language has no data property declared in your OWL for language_name.
    # Add one in Protégé (e.g. #languageName) if you want the name stored.

# =================================================================
# 2. CORE ENTITIES
# =================================================================

<#MapTitle> a rr:TriplesMap;
    rr:logicalTable [ rr:tableName "title" ];
    rr:subjectMap [
        rr:template "http://www.semanticweb.org/antoi/data/resource/title/{title_id}";
        rr:class ont:Title
    ];
    rr:predicateObjectMap [
        rr:predicate ont:primaryTitle;        # OWL: #primaryTitle ✓
        rr:objectMap [ rr:column "primary_title" ]
    ];
    rr:predicateObjectMap [
        rr:predicate ont:startYear;           # OWL: #startYear ✓
        rr:objectMap [ rr:column "start_year"; rr:datatype xsd:string ]
    ];
    rr:predicateObjectMap [
        rr:predicate ont:isClassifiedAs;      # OWL: #isClassifiedAs ✓
        rr:objectMap [
            rr:parentTriplesMap <#MapContentType>;
            rr:joinCondition [ rr:child "content_type_id"; rr:parent "content_type_id" ]
        ]
    ];
    rr:predicateObjectMap [
        rr:predicate ont:isAka;               # OWL: #isAka ✓ (links Title → AlternativeTitle)
        rr:objectMap [
            rr:parentTriplesMap <#MapAlternativeTitle>;
            rr:joinCondition [ rr:child "title_id"; rr:parent "title_id" ]
        ]
    ];
    rr:predicateObjectMap [
        rr:predicate ont:contains;            # OWL: #contains ✓ (links Title → Participation)
        rr:objectMap [
            rr:parentTriplesMap <#MapParticipation>;
            rr:joinCondition [ rr:child "title_id"; rr:parent "title_id" ]
        ]
    ] .

<#MapTalent> a rr:TriplesMap;
    rr:logicalTable [ rr:tableName "talent" ];
    rr:subjectMap [
        rr:template "http://www.semanticweb.org/antoi/data/resource/talent/{talent_id}";
        rr:class ont:Talent
    ];
    rr:predicateObjectMap [
        rr:predicate ont:talentName;          # OWL: #talentName ✓
        rr:objectMap [ rr:column "talent_name" ]
    ];
    rr:predicateObjectMap [
        rr:predicate ont:participatesIn;      # OWL: #participatesIn ✓
        rr:objectMap [
            rr:parentTriplesMap <#MapParticipation>;
            rr:joinCondition [ rr:child "talent_id"; rr:parent "talent_id" ]
        ]
    ] .

# =================================================================
# 3. THE BRIDGE & JUNCTIONS
# =================================================================

<#MapParticipation> a rr:TriplesMap;
    rr:logicalTable [ rr:tableName "title_principal" ];
    rr:subjectMap [
        rr:template "http://www.semanticweb.org/antoi/data/resource/participation/{title_id}_{talent_id}_{ord}";
        rr:class ont:Participation
    ];
    rr:predicateObjectMap [
        rr:predicate ont:as;                  # OWL: #as ✓ (links Participation → Category)
        rr:objectMap [
            rr:parentTriplesMap <#MapCategory>;
            rr:joinCondition [ rr:child "category_id"; rr:parent "category_id" ]
        ]
    ];
    rr:predicateObjectMap [
        rr:predicate ont:job;                 # OWL: #job (was ont:jobDescription before, WRONG)
        rr:objectMap [ rr:column "job" ]
    ] .

# talent_role maps Talent → Role via ont:plays on Participation.
# Since talent_role has (talent_id, role_id, ord) but no title_id, we use
# a SQL view to join with title_principal so we can build the Participation URI.
<#MapParticipationPlaysRole> a rr:TriplesMap;
    rr:logicalTable [ rr:sqlQuery """
        SELECT tp.title_id, tp.talent_id, tp.ord, tr.role_id
        FROM title_principal tp
        JOIN talent_role tr ON tp.talent_id = tr.talent_id
    """ ];
    rr:subjectMap [
        rr:template "http://www.semanticweb.org/antoi/data/resource/participation/{title_id}_{talent_id}_{ord}"
    ];
    rr:predicateObjectMap [
        rr:predicate ont:plays;               # OWL: #plays ✓ (links Participation → Role)
        rr:objectMap [
            rr:parentTriplesMap <#MapRole>;
            rr:joinCondition [ rr:child "role_id"; rr:parent "role_id" ]
        ]
    ] .

<#MapTitleGenre> a rr:TriplesMap;
    rr:logicalTable [ rr:tableName "title_genre" ];
    rr:subjectMap [
        rr:template "http://www.semanticweb.org/antoi/data/resource/title/{title_id}"
    ];
    rr:predicateObjectMap [
        rr:predicate ont:hasGenre;            # OWL: #hasGenre ✓
        rr:objectMap [
            rr:parentTriplesMap <#MapGenre>;
            rr:joinCondition [ rr:child "genre_id"; rr:parent "genre_id" ]
        ]
    ] .

<#MapAlternativeTitle> a rr:TriplesMap;
    rr:logicalTable [ rr:tableName "title_aka" ];
    rr:subjectMap [
        rr:template "http://www.semanticweb.org/antoi/data/resource/alternativeTitle/{title_id}_{ord}";
        rr:class ont:AlternativeTitle
    ];
    rr:predicateObjectMap [
        rr:predicate ont:alternativeTitleName; # OWL: #alternativeTitleName ✓
        rr:objectMap [ rr:column "aka_title" ]
    ];
    rr:predicateObjectMap [
        rr:predicate ont:isFrom;              # OWL: #isFrom (was ont:isFromRegion before, WRONG)
        rr:objectMap [
            rr:parentTriplesMap <#MapRegion>;
            rr:joinCondition [ rr:child "region_id"; rr:parent "region_id" ]
        ]
    ] .

<#MapAkaTitleTypeLink> a rr:TriplesMap;
    rr:logicalTable [ rr:tableName "title_aka_title_type" ];
    rr:subjectMap [
        rr:template "http://www.semanticweb.org/antoi/data/resource/alternativeTitle/{title_id}_{ord}"
    ];
    rr:predicateObjectMap [
        rr:predicate ont:hasType;             # OWL: #hasType (was ont:hasTitleType before, WRONG)
        rr:objectMap [
            rr:parentTriplesMap <#MapTitleType>;
            rr:joinCondition [ rr:child "title_type_id"; rr:parent "title_type_id" ]
        ]
    ] .

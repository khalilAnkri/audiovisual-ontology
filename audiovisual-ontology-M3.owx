    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#AlternativeTitle</IRI>
        <Literal xml:lang="en">An alternative title used to refer to a title in different languages, regions, or contexts, possibly including ordering and additional attributes.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#AlternativeTitle</IRI>
        <Literal xml:lang="en">AlternativeTitle</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:seeAlso"/>
        <IRI>#AlternativeTitle</IRI>
        <Literal xml:lang="en">Alternative_title, Title_aka, TitleAka</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Category</IRI>
        <Literal xml:lang="en">A classification used to categorize the participation of a talent in a title, often describing the nature of their contribution.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Category</IRI>
        <Literal xml:lang="en">Category</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#ContentType</IRI>
        <Literal xml:lang="en">A classification of a title based on its format or type, such as movie, TV series, or short film.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#ContentType</IRI>
        <Literal xml:lang="en">ContentType</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:seeAlso"/>
        <IRI>#ContentType</IRI>
        <Literal xml:lang="en">Content_type</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Genre</IRI>
        <Literal xml:lang="en">A category that describes the thematic or stylistic classification of a title, such as drama, comedy, or action.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Genre</IRI>
        <Literal xml:lang="en">Genre</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Participation</IRI>
        <Literal xml:lang="en">A participation event linking a talent to a title with a specific role, possibly including additional attributes such as job description and participation order.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Participation</IRI>
        <Literal xml:lang="en">Participation</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:seeAlso"/>
        <IRI>#Participation</IRI>
        <Literal xml:lang="en">Title_principal</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Region</IRI>
        <Literal xml:lang="en">A geographical area associated with a title or its alternative versions, such as a country or distribution region.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Region</IRI>
        <Literal xml:lang="en">Region</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Role</IRI>
        <Literal xml:lang="en">A function or role played by a talent in a title, such as actor, director, or producer.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Role</IRI>
        <Literal xml:lang="en">Role</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Talent</IRI>
        <Literal xml:lang="en">A person involved in the creation or participation in a title, such as an actor, director, or writer, described by attributes like name and life dates.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Talent</IRI>
        <Literal xml:lang="en">Talent</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Title</IRI>
        <Literal xml:lang="en">A film, series, or other audiovisual content, characterized by attributes such as title, release year, runtime, and adult content flag.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Title</IRI>
        <Literal xml:lang="en">Title</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#TitleType</IRI>
        <Literal xml:lang="en">A classification describing the type of a title or alternative title, such as original, working title, or international title.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#TitleType</IRI>
        <Literal xml:lang="en">TitleType</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:seeAlso"/>
        <IRI>#TitleType</IRI>
        <Literal xml:lang="en">Title_type</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#additionalAttributes</IRI>
        <Literal xml:lang="en">Additional descriptive information associated with an alternative title that is not captured by the other properties.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#additionalAttributes</IRI>
        <Literal xml:lang="en">additionalAttributes</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#alternativeTitleName</IRI>
        <Literal xml:lang="en">The textual form of an alternative title used for a title in a specific language, region, or context.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#alternativeTitleName</IRI>
        <Literal xml:lang="en">alternativeTitleName</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:seeAlso"/>
        <IRI>#alternativeTitleName</IRI>
        <Literal xml:lang="en">akaTitle</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#alternativeTitleOrd</IRI>
        <Literal xml:lang="en">The ordering or priority assigned to an alternative title among the alternative titles of the same title.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#alternativeTitleOrd</IRI>
        <Literal xml:lang="en">alternativeTitleOrder</Literal>

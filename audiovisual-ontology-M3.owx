    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>http://purl.org/dc/elements/1.1/creator</IRI>
        <Literal xml:lang="en">Authors metadata</Literal>
    </AnnotationAssertion>

@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ont: <https://khalilankri.github.io/audiovisual-ontology/1.0#> .
@prefix res: <https://khalilankri.github.io/audiovisual-ontology/data/> .

# =================================================================
# 1. REFERENCE CLASSES (Dictionaries)
# =================================================================

<#MapCategory> a rr:TriplesMap;

#1. Logical Table (SQL Source)
    rr:logicalTable [ rr:tableName "category" ];

#2. Subject Map (IRI + Type)
    rr:subjectMap [
        rr:template "https://khalilankri.github.io/audiovisual-ontology/data/category/{category_id}";
        rr:class ont:Category
    ];

#3. Predicate-Object Maps (Properties)
    rr:predicateObjectMap [
        rr:predicate ont:categoryName;        
        rr:objectMap [ rr:column "category_name" ]
    ];
    rr:predicateObjectMap [
        rr:predicate rdfs:label;
        rr:objectMap [ rr:column "category_name" ]
    ] .

<#MapRole> a rr:TriplesMap;
    rr:logicalTable [ rr:tableName "role" ];
    rr:subjectMap [
        rr:template "https://khalilankri.github.io/audiovisual-ontology/data/role/{role_id}";
        rr:class ont:Role
    ];
    rr:predicateObjectMap [
        rr:predicate ont:roleName;            
        rr:objectMap [ rr:column "role_name" ]
    ];
    rr:predicateObjectMap [
        rr:predicate rdfs:label;
        rr:objectMap [ rr:column "role_name" ]
    ] .

<#MapGenre> a rr:TriplesMap;
    rr:logicalTable [ rr:tableName "genre" ];
    rr:subjectMap [
        rr:template "https://khalilankri.github.io/audiovisual-ontology/data/genre/{genre_id}";
        rr:class ont:Genre
    ];
    rr:predicateObjectMap [
        rr:predicate ont:genreName;       
        rr:objectMap [ rr:column "genre_name" ]
    ];
    rr:predicateObjectMap [
        rr:predicate rdfs:label;
        rr:objectMap [ rr:column "genre_name" ]
    ] .

<#MapTitleType> a rr:TriplesMap;
    rr:logicalTable [ rr:tableName "title_type" ];
    rr:subjectMap [
        rr:template "https://khalilankri.github.io/audiovisual-ontology/data/titleType/{title_type_id}";
        rr:class ont:TitleType
    ];
    rr:predicateObjectMap [
        rr:predicate ont:title_type_name;    
        rr:objectMap [ rr:column "title_type_name" ]
    ];
    rr:predicateObjectMap [
        rr:predicate rdfs:label;
        rr:objectMap [ rr:column "title_type_name" ]
    ] .

<#MapContentType> a rr:TriplesMap;
    rr:logicalTable [ rr:tableName "content_type" ];
    rr:subjectMap [
        rr:template "https://khalilankri.github.io/audiovisual-ontology/data/contentType/{content_type_id}";
        rr:class ont:ContentType
    ];
    rr:predicateObjectMap [
        rr:predicate ont:content_type_name;   
        rr:objectMap [ rr:column "content_type_name" ]
    ];
    rr:predicateObjectMap [
        rr:predicate rdfs:label;
        rr:objectMap [ rr:column "content_type_name" ]
    ] .

<#MapRegion> a rr:TriplesMap;
    rr:logicalTable [ rr:tableName "region" ];
    rr:subjectMap [
        rr:template "https://khalilankri.github.io/audiovisual-ontology/data/region/{region_id}";
        rr:class ont:Region
    ];
    rr:predicateObjectMap [
        rr:predicate ont:regionName;        
        rr:objectMap [ rr:column "region_name" ]
    ];
    rr:predicateObjectMap [
        rr:predicate rdfs:label;
        rr:objectMap [ rr:column "region_name" ]
    ] .

<#MapLanguage> a rr:TriplesMap;
    rr:logicalTable [ rr:tableName "language" ];
    rr:subjectMap [
        rr:template "https://khalilankri.github.io/audiovisual-ontology/data/language/{language_id}";
        rr:class ont:Language
    ] .

# =================================================================
# 2. CORE ENTITIES
# =================================================================

<#MapTitle> a rr:TriplesMap;
    rr:logicalTable [ rr:tableName "title" ];
    rr:subjectMap [
        rr:template "https://khalilankri.github.io/audiovisual-ontology/data/title/{title_id}";
        rr:class ont:Title
    ];

# Data Properties
    rr:predicateObjectMap [
        rr:predicate ont:primaryTitle;        
        rr:objectMap [ rr:column "primary_title" ]
    ];
    rr:predicateObjectMap [
        rr:predicate ont:startYear;          
        rr:objectMap [ rr:column "start_year"; rr:datatype xsd:string ]
    ];

# Object Property: Classification
    rr:predicateObjectMap [
        rr:predicate ont:isClassifiedAs;      
        rr:objectMap [
            rr:parentTriplesMap <#MapContentType>;
            rr:joinCondition [ rr:child "content_type_id"; rr:parent "content_type_id" ]
        ]
    ];
    rr:predicateObjectMap [
        rr:predicate ont:isAka;               
        rr:objectMap [
            rr:parentTriplesMap <#MapAlternativeTitle>;
            rr:joinCondition [ rr:child "title_id"; rr:parent "title_id" ]
        ]
    ];
    rr:predicateObjectMap [
        rr:predicate ont:contains;           
        rr:objectMap [
            rr:parentTriplesMap <#MapParticipation>;
            rr:joinCondition [ rr:child "title_id"; rr:parent "title_id" ]
        ]
    ];
    
# Human-readable label
    rr:predicateObjectMap [
        rr:predicate rdfs:label;
        rr:objectMap [ rr:column "primary_title" ]
    ] .

<#MapTalent> a rr:TriplesMap;
    rr:logicalTable [ rr:tableName "talent" ];


    rr:subjectMap [
        rr:template "https://khalilankri.github.io/audiovisual-ontology/data/talent/{talent_id}";
        rr:class ont:Talent
    ];


    rr:predicateObjectMap [
        rr:predicate ont:talentName;          
        rr:objectMap [ rr:column "talent_name" ]
    ];


    rr:predicateObjectMap [
        rr:predicate ont:participatesIn;      
        rr:objectMap [
            rr:parentTriplesMap <#MapParticipation>;
            rr:joinCondition [ rr:child "talent_id"; rr:parent "talent_id" ]
        ]
    ];

    rr:predicateObjectMap [
        rr:predicate rdfs:label;
        rr:objectMap [ rr:column "talent_name" ]
    ] .

# =================================================================
# 3. THE BRIDGE & JUNCTIONS
# =================================================================

<#MapParticipation> a rr:TriplesMap;
    rr:logicalTable [ rr:tableName "title_principal" ];

    # Composite IRI from 3 columns 
    rr:subjectMap [
        rr:template "https://khalilankri.github.io/audiovisual-ontology/data/participation/{title_id}_{talent_id}_{ord}";
        rr:class ont:Participation
    ];

     # Category of participation (e.g., actor, director)
    rr:predicateObjectMap [
        rr:predicate ont:as;                  
        rr:objectMap [
            rr:parentTriplesMap <#MapCategory>;
            rr:joinCondition [ rr:child "category_id"; rr:parent "category_id" ]
        ]
    ];

    # Job description
    rr:predicateObjectMap [
        rr:predicate ont:job;                 
        rr:objectMap [ rr:column "job" ]
    ] .

<#MapParticipationPlaysRole> a rr:TriplesMap;
    rr:logicalTable [ rr:sqlQuery """
        SELECT tp.title_id, tp.talent_id, tp.ord, tr.role_id
        FROM title_principal tp
        JOIN talent_role tr ON tp.talent_id = tr.talent_id
    """ ];
    rr:subjectMap [
        rr:template "https://khalilankri.github.io/audiovisual-ontology/data/participation/{title_id}_{talent_id}_{ord}"
    ];
    rr:predicateObjectMap [
        rr:predicate ont:plays;               
        rr:objectMap [
            rr:parentTriplesMap <#MapRole>;
            rr:joinCondition [ rr:child "role_id"; rr:parent "role_id" ]
        ]
    ] .

<#MapTitleGenre> a rr:TriplesMap;
    rr:logicalTable [ rr:tableName "title_genre" ];
    rr:subjectMap [
        rr:template "https://khalilankri.github.io/audiovisual-ontology/data/title/{title_id}"
    ];
    rr:predicateObjectMap [
        rr:predicate ont:hasGenre;         
        rr:objectMap [
            rr:parentTriplesMap <#MapGenre>;
            rr:joinCondition [ rr:child "genre_id"; rr:parent "genre_id" ]
        ]
    ] .

<#MapAlternativeTitle> a rr:TriplesMap;
    rr:logicalTable [ rr:tableName "title_aka" ];
    rr:subjectMap [
        rr:template "https://khalilankri.github.io/audiovisual-ontology/data/alternativeTitle/{title_id}_{ord}";
        rr:class ont:AlternativeTitle
    ];
    rr:predicateObjectMap [
        rr:predicate ont:alternativeTitleName; 
        rr:objectMap [ rr:column "aka_title" ]
    ];
    rr:predicateObjectMap [
        rr:predicate ont:isFrom;             
        rr:objectMap [
            rr:parentTriplesMap <#MapRegion>;
            rr:joinCondition [ rr:child "region_id"; rr:parent "region_id" ]
        ]
    ];
    rr:predicateObjectMap [
        rr:predicate rdfs:label;
        rr:objectMap [ rr:column "aka_title" ]
    ] .

<#MapAkaTitleTypeLink> a rr:TriplesMap;
    rr:logicalTable [ rr:tableName "title_aka_title_type" ];
    rr:subjectMap [
        rr:template "https://khalilankri.github.io/audiovisual-ontology/data/alternativeTitle/{title_id}_{ord}"
    ];
    rr:predicateObjectMap [
        rr:predicate ont:hasType;            
        rr:objectMap [
            rr:parentTriplesMap <#MapTitleType>;
            rr:joinCondition [ rr:child "title_type_id"; rr:parent "title_type_id" ]
        ]
    ] .
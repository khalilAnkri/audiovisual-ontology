    "@language" : "en",
    "@value" : "1"
  } ]
}, {
  "@id" : "https://khalilankri.github.io/audiovisual-ontology/1.0#AlternativeTitle",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An alternative title used to refer to a title in different languages, regions, or contexts, possibly including ordering and additional attributes."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "AlternativeTitle"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@language" : "en",
    "@value" : "Alternative_title, Title_aka, TitleAka"
  } ]
}, {
  "@id" : "https://khalilankri.github.io/audiovisual-ontology/1.0#Category",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A classification used to categorize the participation of a talent in a title, often describing the nature of their contribution."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Category"
  } ]
}, {
  "@id" : "https://khalilankri.github.io/audiovisual-ontology/1.0#ContentType",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A classification of a title based on its format or type, such as movie, TV series, or short film."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "ContentType"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@language" : "en",
    "@value" : "Content_type"
  } ]
}, {
  "@id" : "https://khalilankri.github.io/audiovisual-ontology/1.0#Genre",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A category that describes the thematic or stylistic classification of a title, such as drama, comedy, or action."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Genre"
  } ]
}, {
  "@id" : "https://khalilankri.github.io/audiovisual-ontology/1.0#Participation",

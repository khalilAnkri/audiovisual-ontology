  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A person involved in the creation or participation in a title, such as an actor, director, or writer, described by attributes like name and life dates."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Talent"
  } ]
}, {
  "@id" : "https://khalilankri.github.io/audiovisual-ontology/1.0#Title",

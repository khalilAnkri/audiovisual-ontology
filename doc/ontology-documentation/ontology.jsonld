    "@language" : "en",
    "@value" : "A film, series, or other audiovisual content, characterized by attributes such as title, release year, runtime, and adult content flag."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Title"
  } ]

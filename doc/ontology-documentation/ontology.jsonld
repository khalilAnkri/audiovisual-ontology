  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A geographical area associated with a title or its alternative versions, such as a country or distribution region."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Region"
  } ]
}, {
  "@id" : "https://khalilankri.github.io/audiovisual-ontology/1.0#Role",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A function or role played by a talent in a title, such as actor, director, or producer."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Role"
  } ]
}, {

    <owl:Class rdf:about="https://khalilankri.github.io/audiovisual-ontology/1.0#Genre">
        <rdfs:comment xml:lang="en">A category that describes the thematic or stylistic classification of a title, such as drama, comedy, or action.</rdfs:comment>

<?xml version="1.0"?>
<rdf:RDF xmlns="https://khalilankri.github.io/audiovisual-ontology/1.0#"
     xml:base="https://khalilankri.github.io/audiovisual-ontology/1.0"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:terms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="https://khalilankri.github.io/audiovisual-ontology/1.0">
        <dc:creator xml:lang="en">ANKRI Mohamed-Khalil</dc:creator>
        <dc:creator xml:lang="en">MICHON Charlotte</dc:creator>
        <dc:creator xml:lang="en">PAULIS Antoine</dc:creator>
        <rdfs:comment xml:lang="en">This ontology is about audiovisual domain, based on IMDb database and adapted for generic shared knowledge. It aims to be deployed to combine a catalogue multi-critera search tool and an analysis tool.</rdfs:comment>
        <rdfs:label xml:lang="en">AudiovisualOntology</rdfs:label>
        <owl:versionInfo xml:lang="en">1</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/elements/1.1/creator -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/creator"/>
    


    <!-- http://purl.org/dc/elements/1.1/publisher -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/publisher">
        <rdfs:comment xml:lang="en">Publisher metadata</rdfs:comment>
    </owl:AnnotationProperty>
    


    <!-- http://purl.org/dc/terms/license -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license">
        <rdfs:comment xml:lang="en">License metadata</rdfs:comment>
    </owl:AnnotationProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://khalilankri.github.io/audiovisual-ontology/1.0#as -->


    <owl:ObjectProperty rdf:about="https://khalilankri.github.io/audiovisual-ontology/1.0#as">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="https://khalilankri.github.io/audiovisual-ontology/1.0#Participation"/>
        <rdfs:range rdf:resource="https://khalilankri.github.io/audiovisual-ontology/1.0#Category"/>
        <rdfs:comment xml:lang="en">Associates a participation event with a category describing the nature of the contribution.</rdfs:comment>
        <rdfs:label xml:lang="en">hasCategory</rdfs:label>
        <rdfs:seeAlso xml:lang="en">as (generic name)</rdfs:seeAlso>
    </owl:ObjectProperty>
    


    <!-- https://khalilankri.github.io/audiovisual-ontology/1.0#contains -->


    <owl:ObjectProperty rdf:about="https://khalilankri.github.io/audiovisual-ontology/1.0#contains">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="https://khalilankri.github.io/audiovisual-ontology/1.0#Title"/>
        <rdfs:range rdf:resource="https://khalilankri.github.io/audiovisual-ontology/1.0#Participation"/>
        <rdfs:comment xml:lang="en">Relates a title to the participation events associated with it.</rdfs:comment>
        <rdfs:label xml:lang="en">contains</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://khalilankri.github.io/audiovisual-ontology/1.0#hasGenre -->


    <owl:ObjectProperty rdf:about="https://khalilankri.github.io/audiovisual-ontology/1.0#hasGenre">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="https://khalilankri.github.io/audiovisual-ontology/1.0#Title"/>
        <rdfs:range rdf:resource="https://khalilankri.github.io/audiovisual-ontology/1.0#Genre"/>
        <rdfs:comment xml:lang="en">Associates a title with one or more genres describing its thematic classification.</rdfs:comment>
        <rdfs:label xml:lang="en">hasGenre</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://khalilankri.github.io/audiovisual-ontology/1.0#hasType -->


    <owl:ObjectProperty rdf:about="https://khalilankri.github.io/audiovisual-ontology/1.0#hasType">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="https://khalilankri.github.io/audiovisual-ontology/1.0#AlternativeTitle"/>
        <rdfs:range rdf:resource="https://khalilankri.github.io/audiovisual-ontology/1.0#TitleType"/>
        <rdfs:comment xml:lang="en">Associates an alternative title with its type, such as original, working title, or international title.</rdfs:comment>
        <rdfs:label xml:lang="en">hasTypeTitle</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://khalilankri.github.io/audiovisual-ontology/1.0#isAka -->


    <owl:ObjectProperty rdf:about="https://khalilankri.github.io/audiovisual-ontology/1.0#isAka">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="https://khalilankri.github.io/audiovisual-ontology/1.0#Title"/>
        <rdfs:range rdf:resource="https://khalilankri.github.io/audiovisual-ontology/1.0#AlternativeTitle"/>
        <rdfs:comment xml:lang="en">Associates a title with its alternative titles used in different contexts such as languages or regions.</rdfs:comment>
        <rdfs:label xml:lang="en">hasAlternativeTitle</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://khalilankri.github.io/audiovisual-ontology/1.0#isClassifiedAs -->


    <owl:ObjectProperty rdf:about="https://khalilankri.github.io/audiovisual-ontology/1.0#isClassifiedAs">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="https://khalilankri.github.io/audiovisual-ontology/1.0#Title"/>
        <rdfs:range rdf:resource="https://khalilankri.github.io/audiovisual-ontology/1.0#ContentType"/>
        <rdfs:comment xml:lang="en">Relates a title to its content type, indicating the format of the content such as movie or TV series.</rdfs:comment>
        <rdfs:label xml:lang="en">isClassifiedAs</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://khalilankri.github.io/audiovisual-ontology/1.0#isFrom -->


    <owl:ObjectProperty rdf:about="https://khalilankri.github.io/audiovisual-ontology/1.0#isFrom">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="https://khalilankri.github.io/audiovisual-ontology/1.0#AlternativeTitle"/>
        <rdfs:range rdf:resource="https://khalilankri.github.io/audiovisual-ontology/1.0#Region"/>
        <rdfs:comment xml:lang="en">Indicates the region associated with an alternative title, such as the country where it is used.</rdfs:comment>
        <rdfs:label xml:lang="en">isFromRegion</rdfs:label>
        <rdfs:seeAlso xml:lang="en">isFrom</rdfs:seeAlso>
    </owl:ObjectProperty>
    


    <!-- https://khalilankri.github.io/audiovisual-ontology/1.0#participatesIn -->


    <owl:ObjectProperty rdf:about="https://khalilankri.github.io/audiovisual-ontology/1.0#participatesIn">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="https://khalilankri.github.io/audiovisual-ontology/1.0#Talent"/>
        <rdfs:range rdf:resource="https://khalilankri.github.io/audiovisual-ontology/1.0#Participation"/>
        <rdfs:comment xml:lang="en">Links a participation event to the title in which the talent is involved.</rdfs:comment>
        <rdfs:label xml:lang="en">participatesIn</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://khalilankri.github.io/audiovisual-ontology/1.0#plays -->


    <owl:ObjectProperty rdf:about="https://khalilankri.github.io/audiovisual-ontology/1.0#plays">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="https://khalilankri.github.io/audiovisual-ontology/1.0#Participation"/>
        <rdfs:range rdf:resource="https://khalilankri.github.io/audiovisual-ontology/1.0#Role"/>
        <rdfs:comment xml:lang="en">Associates a participation event with the role performed by the talent in a title.</rdfs:comment>
        <rdfs:label xml:lang="en">plays</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://khalilankri.github.io/audiovisual-ontology/1.0#additionalAttributes -->


    <owl:DatatypeProperty rdf:about="https://khalilankri.github.io/audiovisual-ontology/1.0#additionalAttributes">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="https://khalilankri.github.io/audiovisual-ontology/1.0#AlternativeTitle"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Additional descriptive information associated with an alternative title that is not captured by the other properties.</rdfs:comment>
        <rdfs:label xml:lang="en">additionalAttributes</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://khalilankri.github.io/audiovisual-ontology/1.0#alternativeTitleName -->


    <owl:DatatypeProperty rdf:about="https://khalilankri.github.io/audiovisual-ontology/1.0#alternativeTitleName">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="https://khalilankri.github.io/audiovisual-ontology/1.0#AlternativeTitle"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The textual form of an alternative title used for a title in a specific language, region, or context.</rdfs:comment>
        <rdfs:label xml:lang="en">alternativeTitleName</rdfs:label>
        <rdfs:seeAlso xml:lang="en">akaTitle</rdfs:seeAlso>
    </owl:DatatypeProperty>
    


    <!-- https://khalilankri.github.io/audiovisual-ontology/1.0#alternativeTitleOrd -->


    <owl:DatatypeProperty rdf:about="https://khalilankri.github.io/audiovisual-ontology/1.0#alternativeTitleOrd">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="https://khalilankri.github.io/audiovisual-ontology/1.0#AlternativeTitle"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">The ordering or priority assigned to an alternative title among the alternative titles of the same title.</rdfs:comment>
        <rdfs:label xml:lang="en">alternativeTitleOrder</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://khalilankri.github.io/audiovisual-ontology/1.0#birthYear -->


    <owl:DatatypeProperty rdf:about="https://khalilankri.github.io/audiovisual-ontology/1.0#birthYear">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="https://khalilankri.github.io/audiovisual-ontology/1.0#Talent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">The year in which a talent was born.</rdfs:comment>
        <rdfs:label xml:lang="en">birthYear</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://khalilankri.github.io/audiovisual-ontology/1.0#categoryName -->


    <owl:DatatypeProperty rdf:about="https://khalilankri.github.io/audiovisual-ontology/1.0#categoryName">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="https://khalilankri.github.io/audiovisual-ontology/1.0#Category"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The name of a category describing the nature of a participation or contribution.</rdfs:comment>
        <rdfs:label xml:lang="en">categoryName</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://khalilankri.github.io/audiovisual-ontology/1.0#content_type_name -->


    <owl:DatatypeProperty rdf:about="https://khalilankri.github.io/audiovisual-ontology/1.0#content_type_name">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="https://khalilankri.github.io/audiovisual-ontology/1.0#ContentType"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The name of a content type describing the format of a title, such as movie, short, or TV series.</rdfs:comment>
        <rdfs:label xml:lang="en">contentTypeName</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://khalilankri.github.io/audiovisual-ontology/1.0#deathYear -->


    <owl:DatatypeProperty rdf:about="https://khalilankri.github.io/audiovisual-ontology/1.0#deathYear">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="https://khalilankri.github.io/audiovisual-ontology/1.0#Talent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">The year in which a talent died.</rdfs:comment>
        <rdfs:label xml:lang="en">deathYear</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://khalilankri.github.io/audiovisual-ontology/1.0#endYear -->


    <owl:DatatypeProperty rdf:about="https://khalilankri.github.io/audiovisual-ontology/1.0#endYear">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="https://khalilankri.github.io/audiovisual-ontology/1.0#Title"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">The year in which a title ended, for example the ending year of a series.</rdfs:comment>
        <rdfs:label xml:lang="en">endYear</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://khalilankri.github.io/audiovisual-ontology/1.0#genreName -->


    <owl:DatatypeProperty rdf:about="https://khalilankri.github.io/audiovisual-ontology/1.0#genreName">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="https://khalilankri.github.io/audiovisual-ontology/1.0#Genre"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The name of a genre used to classify a title, such as drama, comedy, or action.</rdfs:comment>
        <rdfs:label xml:lang="en">genreName</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://khalilankri.github.io/audiovisual-ontology/1.0#isAdult -->


    <owl:DatatypeProperty rdf:about="https://khalilankri.github.io/audiovisual-ontology/1.0#isAdult">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="https://khalilankri.github.io/audiovisual-ontology/1.0#Title"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Indicates whether a title is intended for adult audiences.</rdfs:comment>
        <rdfs:label xml:lang="en">isAdult</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://khalilankri.github.io/audiovisual-ontology/1.0#isOriginalTitle -->


    <owl:DatatypeProperty rdf:about="https://khalilankri.github.io/audiovisual-ontology/1.0#isOriginalTitle">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="https://khalilankri.github.io/audiovisual-ontology/1.0#AlternativeTitle"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Indicates whether an alternative title is the original title of the associated title.e</rdfs:comment>
        <rdfs:label xml:lang="en">isOriginalTitle</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://khalilankri.github.io/audiovisual-ontology/1.0#job -->


    <owl:DatatypeProperty rdf:about="https://khalilankri.github.io/audiovisual-ontology/1.0#job">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="https://khalilankri.github.io/audiovisual-ontology/1.0#Participation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">A textual description of the specific job or function performed by a talent in a participation.</rdfs:comment>
        <rdfs:label xml:lang="en">jobDescription</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://khalilankri.github.io/audiovisual-ontology/1.0#originalTitle -->


    <owl:DatatypeProperty rdf:about="https://khalilankri.github.io/audiovisual-ontology/1.0#originalTitle">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="https://khalilankri.github.io/audiovisual-ontology/1.0#Title"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The original title text assigned to a title.</rdfs:comment>
        <rdfs:label xml:lang="en">originalTitle</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://khalilankri.github.io/audiovisual-ontology/1.0#participationOrd -->


    <owl:DatatypeProperty rdf:about="https://khalilankri.github.io/audiovisual-ontology/1.0#participationOrd">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="https://khalilankri.github.io/audiovisual-ontology/1.0#Participation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">The ordering or ranking of a participation within a title, for example to indicate main or secondary contributors.</rdfs:comment>
        <rdfs:label xml:lang="en">participationOrder</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://khalilankri.github.io/audiovisual-ontology/1.0#primaryTitle -->


    <owl:DatatypeProperty rdf:about="https://khalilankri.github.io/audiovisual-ontology/1.0#primaryTitle">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="https://khalilankri.github.io/audiovisual-ontology/1.0#Title"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The primary title text used as the main name of a title.</rdfs:comment>
        <rdfs:label xml:lang="en">primaryTitle</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://khalilankri.github.io/audiovisual-ontology/1.0#regionName -->


    <owl:DatatypeProperty rdf:about="https://khalilankri.github.io/audiovisual-ontology/1.0#regionName">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="https://khalilankri.github.io/audiovisual-ontology/1.0#Region"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The name of a region associated with an alternative title or distribution context.</rdfs:comment>
        <rdfs:label xml:lang="en">regionName</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://khalilankri.github.io/audiovisual-ontology/1.0#roleName -->


    <owl:DatatypeProperty rdf:about="https://khalilankri.github.io/audiovisual-ontology/1.0#roleName">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="https://khalilankri.github.io/audiovisual-ontology/1.0#Role"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The name of a role that a talent may have in relation to a title, such as actor, director, or writer.</rdfs:comment>
        <rdfs:label xml:lang="en">roleName</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://khalilankri.github.io/audiovisual-ontology/1.0#runtimeMinutes -->


    <owl:DatatypeProperty rdf:about="https://khalilankri.github.io/audiovisual-ontology/1.0#runtimeMinutes">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="https://khalilankri.github.io/audiovisual-ontology/1.0#Title"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The duration of a title expressed in minutes.</rdfs:comment>
        <rdfs:label xml:lang="en">runtimeInMinutes</rdfs:label>
        <rdfs:seeAlso xml:lang="en">runtimeMinutes</rdfs:seeAlso>
    </owl:DatatypeProperty>
    


    <!-- https://khalilankri.github.io/audiovisual-ontology/1.0#startYear -->


    <owl:DatatypeProperty rdf:about="https://khalilankri.github.io/audiovisual-ontology/1.0#startYear">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="https://khalilankri.github.io/audiovisual-ontology/1.0#Title"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">The year in which a title was first released or started airing.</rdfs:comment>
        <rdfs:label xml:lang="en">startYear</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://khalilankri.github.io/audiovisual-ontology/1.0#talentName -->


    <owl:DatatypeProperty rdf:about="https://khalilankri.github.io/audiovisual-ontology/1.0#talentName">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="https://khalilankri.github.io/audiovisual-ontology/1.0#Talent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The name of a talent involved in a title, such as an actor, director, or writer.</rdfs:comment>
        <rdfs:label xml:lang="en">talentName</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://khalilankri.github.io/audiovisual-ontology/1.0#title_type_name -->



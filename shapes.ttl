        sh:name "content_type_name" ;
        sh:message "A ContentType must have exactly one non-empty content_type_name."
    ] .

# --- 9. REGION ---
shape:RegionShape a sh:NodeShape ;
    sh:targetClass ont:Region ;
    sh:name "RegionShape" ;
    sh:description "Every Region must have at least one non-empty regionName." ;

    sh:property [
        sh:path ont:regionName ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:minLength 1 ;
        sh:name "regionName" ;
        sh:message "A Region must have at least one non-empty regionName."
    ] .

# --- 10. TITLE TYPE ---
shape:TitleTypeShape a sh:NodeShape ;
    sh:targetClass ont:TitleType ;
    sh:name "TitleTypeShape" ;
    sh:description "Every TitleType must have a non-empty title_type_name." ;

    sh:property [
        sh:path ont:title_type_name ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:minLength 1 ;
        sh:name "title_type_name" ;
        sh:message "A TitleType must have exactly one non-empty title_type_name."
    ] .

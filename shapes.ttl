@prefix sh:    <http://www.w3.org/ns/shacl#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix ont:   <https://khalilankri.github.io/audiovisual-ontology/1.0#> .
@prefix shape: <https://khalilankri.github.io/audiovisual-ontology/shapes/> .


# =================================================================
# SECTION A — CLASS DISJOINTNESS
# No individual may belong to two distinct domain classes at once.
# Mirrors the OWL DisjointClasses axiom at the validation level,
# independently of any reasoner.
# =================================================================

shape:TitleDisjointShape a sh:NodeShape ;
    sh:targetClass ont:Title ;
    sh:name "TitleDisjointShape" ;
    sh:description "A Title must not simultaneously belong to any other domain class." ;
    sh:not [ sh:class ont:Talent ] ;
    sh:not [ sh:class ont:Participation ] ;
    sh:not [ sh:class ont:Genre ] ;
    sh:not [ sh:class ont:ContentType ] ;
    sh:not [ sh:class ont:AlternativeTitle ] ;
    sh:not [ sh:class ont:Category ] ;
    sh:not [ sh:class ont:Role ] ;
    sh:not [ sh:class ont:Region ] ;
    sh:not [ sh:class ont:TitleType ] .

shape:TalentDisjointShape a sh:NodeShape ;
    sh:targetClass ont:Talent ;
    sh:name "TalentDisjointShape" ;
    sh:description "A Talent must not simultaneously belong to any other domain class." ;
    sh:not [ sh:class ont:Title ] ;
    sh:not [ sh:class ont:Participation ] ;
    sh:not [ sh:class ont:Genre ] ;
    sh:not [ sh:class ont:ContentType ] ;
    sh:not [ sh:class ont:AlternativeTitle ] ;
    sh:not [ sh:class ont:Category ] ;
    sh:not [ sh:class ont:Role ] ;
    sh:not [ sh:class ont:Region ] ;
    sh:not [ sh:class ont:TitleType ] .

shape:ParticipationDisjointShape a sh:NodeShape ;
    sh:targetClass ont:Participation ;
    sh:name "ParticipationDisjointShape" ;
    sh:description "A Participation must not simultaneously belong to any other domain class." ;

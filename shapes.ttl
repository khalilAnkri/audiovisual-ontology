shape:DomainContentTypeNameShape a sh:NodeShape ;
    sh:targetSubjectsOf ont:content_type_name ;
    sh:name "DomainContentTypeNameShape" ;
    sh:description "ont:content_type_name may only appear on ont:ContentType individuals." ;
    sh:class ont:ContentType ;
    sh:message "ont:content_type_name used on a non-ContentType subject." .


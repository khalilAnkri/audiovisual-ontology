        sh:name "genreName" ;
        sh:message "A Genre must have exactly one non-empty genreName."
    ] .

# --- 8. CONTENT TYPE ---
shape:ContentTypeShape a sh:NodeShape ;
    sh:targetClass ont:ContentType ;
    sh:name "ContentTypeShape" ;
    sh:description "Every ContentType must have a non-empty content_type_name." ;

    sh:property [
        sh:path ont:content_type_name ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;

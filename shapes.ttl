    sh:not [ sh:class ont:Genre ] ;
    sh:not [ sh:class ont:ContentType ] ;
    sh:not [ sh:class ont:AlternativeTitle ] ;
    sh:not [ sh:class ont:Category ] ;
    sh:not [ sh:class ont:Role ] ;
    sh:not [ sh:class ont:TitleType ] .

shape:TitleTypeDisjointShape a sh:NodeShape ;
    sh:targetClass ont:TitleType ;
    sh:name "TitleTypeDisjointShape" ;
    sh:description "A TitleType must not simultaneously belong to any other domain class." ;
    sh:not [ sh:class ont:Title ] ;
    sh:not [ sh:class ont:Talent ] ;
    sh:not [ sh:class ont:Participation ] ;
    sh:not [ sh:class ont:Genre ] ;
    sh:not [ sh:class ont:ContentType ] ;
    sh:not [ sh:class ont:AlternativeTitle ] ;
    sh:not [ sh:class ont:Category ] ;
    sh:not [ sh:class ont:Role ] ;
    sh:not [ sh:class ont:Region ] .


# =================================================================
# SECTION B — DOMAIN VALIDATION (SPARQL-based property shapes)
# Each shape targets every triple using the given property and
# checks that its SUBJECT is of the declared domain class.
# =================================================================

# --- ont:primaryTitle domain: Title only ---
shape:DomainPrimaryTitleShape a sh:NodeShape ;
    sh:targetSubjectsOf ont:primaryTitle ;
    sh:name "DomainPrimaryTitleShape" ;
    sh:description "ont:primaryTitle may only appear on ont:Title individuals." ;
    sh:class ont:Title ;
    sh:message "ont:primaryTitle used on a non-Title subject. Only ont:Title individuals may have this property." .

# --- ont:startYear domain: Title only ---
shape:DomainStartYearShape a sh:NodeShape ;
    sh:targetSubjectsOf ont:startYear ;
    sh:name "DomainStartYearShape" ;
    sh:description "ont:startYear may only appear on ont:Title individuals." ;
    sh:class ont:Title ;
    sh:message "ont:startYear used on a non-Title subject." .

# --- ont:isClassifiedAs domain: Title only ---
shape:DomainIsClassifiedAsShape a sh:NodeShape ;
    sh:targetSubjectsOf ont:isClassifiedAs ;
    sh:name "DomainIsClassifiedAsShape" ;
    sh:description "ont:isClassifiedAs may only be used by ont:Title individuals." ;
    sh:class ont:Title ;
    sh:message "ont:isClassifiedAs used on a non-Title subject. Domain is ont:Title." .

# --- ont:contains domain: Title only ---
shape:DomainContainsShape a sh:NodeShape ;
    sh:targetSubjectsOf ont:contains ;
    sh:name "DomainContainsShape" ;
    sh:description "ont:contains may only be used by ont:Title individuals." ;
    sh:class ont:Title ;
    sh:message "ont:contains used on a non-Title subject. Domain is ont:Title." .

# --- ont:hasGenre domain: Title only ---

# =================================================================
# SECTION C — RANGE + CARDINALITY + FORMAT 
# =================================================================

# --- 1. TITLE ---
shape:TitleShape a sh:NodeShape ;
    sh:targetClass ont:Title ;
    sh:name "TitleShape" ;
    sh:description "Every Title must have exactly one primaryTitle string and exactly one ContentType classification." ;

    sh:property [
        sh:path ont:primaryTitle ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:minLength 1 ;
        sh:name "primaryTitle" ;
        sh:message "A Title must have exactly one non-empty primaryTitle of type xsd:string."
    ] ;

    sh:property [
        sh:path ont:isClassifiedAs ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class ont:ContentType ;
        sh:name "isClassifiedAs" ;
        sh:message "A Title must be classified as exactly one ContentType."
    ] ;

    sh:property [
        sh:path ont:contains ;
        sh:class ont:Participation ;
        sh:name "contains" ;
        sh:message "The contains property must point to a Participation individual."
    ] ;

    sh:property [
        sh:path ont:hasGenre ;
        sh:class ont:Genre ;
        sh:name "hasGenre" ;
        sh:message "The hasGenre property must point to a Genre individual."
    ] ;

    sh:property [
        sh:path ont:isAka ;
        sh:class ont:AlternativeTitle ;
        sh:name "isAka" ;
        sh:message "The isAka property must point to an AlternativeTitle individual."
    ] ;

    # startYear is optional but if present must be a 4-digit year string
    sh:property [
        sh:path ont:startYear ;
        sh:datatype xsd:integer ;
        sh:minInclusive 1888 ;
        sh:maxInclusive 2030 ;
        sh:message "startYear must be an integer between 1888 (first film) and 2030."
    ] .

# --- 2. TALENT ---
shape:TalentShape a sh:NodeShape ;
    sh:targetClass ont:Talent ;
    sh:name "TalentShape" ;
    sh:description "Every Talent must have exactly one non-empty talentName." ;

    sh:property [
        sh:path ont:talentName ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:minLength 1 ;
        sh:name "talentName" ;
        sh:message "A Talent must have exactly one non-empty talentName of type xsd:string."
    ] ;

    sh:property [
        sh:path ont:participatesIn ;
        sh:class ont:Participation ;
        sh:name "participatesIn" ;
        sh:message "The participatesIn property must point to a Participation individual."
    ] .

# --- 3. PARTICIPATION ---
shape:ParticipationShape a sh:NodeShape ;
    sh:targetClass ont:Participation ;
    sh:name "ParticipationShape" ;
    sh:description "Every Participation must be linked to a Category (ont:as), be reachable from a Title (ont:contains), and be reachable from a Talent (ont:participatesIn)." ;

    sh:property [
        sh:path ont:as ;
        sh:minCount 1 ;
        sh:class ont:Category ;
        sh:name "as" ;
        sh:message "A Participation must have at least one ont:as pointing to a Category."
    ] ;

    sh:property [
        sh:path ont:plays ;
        sh:class ont:Role ;
        sh:name "plays" ;
        sh:message "The plays property must point to a Role individual."
    ] ;

    sh:property [
        sh:path ont:job ;
        sh:datatype xsd:string ;
        sh:name "job" ;
        sh:message "The job property must be of type xsd:string."
    ] ;

    # Inverse reachability: every Participation must be referenced by at least one Title
    sh:property [
        sh:path [ sh:inversePath ont:contains ] ;
        sh:minCount 1 ;
        sh:class ont:Title ;
        sh:name "inverseContains" ;
        sh:message "A Participation must be referenced by at least one Title via ont:contains."
    ] ;

    # Inverse reachability: every Participation must be referenced by at least one Talent
    sh:property [
        sh:path [ sh:inversePath ont:participatesIn ] ;
        sh:minCount 1 ;
        sh:class ont:Talent ;
        sh:name "inverseParticipatesIn" ;
        sh:message "A Participation must be referenced by at least one Talent via ont:participatesIn."
    ] .

# --- 4. ALTERNATIVE TITLE ---
shape:AlternativeTitleShape a sh:NodeShape ;
    sh:targetClass ont:AlternativeTitle ;
    sh:name "AlternativeTitleShape" ;
    sh:description "Every AlternativeTitle must have a non-empty name and be reachable from a Title." ;

    sh:property [
        sh:path ont:alternativeTitleName ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:minLength 1 ;
        sh:name "alternativeTitleName" ;
        sh:message "An AlternativeTitle must have exactly one non-empty alternativeTitleName."
    ] ;

    sh:property [
        sh:path ont:isFrom ;
        sh:class ont:Region ;
        sh:name "isFrom" ;
        sh:message "The isFrom property must point to a Region individual."
    ] ;

    sh:property [
        sh:path ont:hasType ;
        sh:class ont:TitleType ;
        sh:name "hasType" ;
        sh:message "The hasType property must point to a TitleType individual."
    ] ;

    # Inverse reachability: every AlternativeTitle must be referenced by a Title
    sh:property [
        sh:path [ sh:inversePath ont:isAka ] ;
        sh:minCount 1 ;
        sh:class ont:Title ;
        sh:name "inverseIsAka" ;
        sh:message "An AlternativeTitle must be referenced by at least one Title via ont:isAka."
    ] .

# --- 5. CATEGORY ---
shape:CategoryShape a sh:NodeShape ;
    sh:targetClass ont:Category ;
    sh:name "CategoryShape" ;
    sh:description "Every Category must have a non-empty categoryName." ;

    sh:property [
        sh:path ont:categoryName ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:minLength 1 ;
        sh:name "categoryName" ;
        sh:message "A Category must have exactly one non-empty categoryName."
    ] .


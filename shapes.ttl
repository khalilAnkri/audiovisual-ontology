    sh:targetSubjectsOf ont:hasGenre ;
    sh:name "DomainHasGenreShape" ;
    sh:description "ont:hasGenre may only be used by ont:Title individuals." ;
    sh:class ont:Title ;
    sh:message "ont:hasGenre used on a non-Title subject. Domain is ont:Title." .

# --- ont:isAka domain: Title only ---
shape:DomainIsAkaShape a sh:NodeShape ;
    sh:targetSubjectsOf ont:isAka ;
    sh:name "DomainIsAkaShape" ;
    sh:description "ont:isAka may only be used by ont:Title individuals." ;
    sh:class ont:Title ;
    sh:message "ont:isAka used on a non-Title subject. Domain is ont:Title." .


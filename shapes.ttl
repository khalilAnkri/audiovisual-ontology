        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:minLength 1 ;
        sh:name "roleName" ;
        sh:message "A Role must have exactly one non-empty roleName."
    ] .

# --- 7. GENRE ---
shape:GenreShape a sh:NodeShape ;
    sh:targetClass ont:Genre ;
    sh:name "GenreShape" ;
    sh:description "Every Genre must have a non-empty genreName." ;

    sh:property [
        sh:path ont:genreName ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;

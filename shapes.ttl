    sh:not [ sh:class ont:ContentType ] ;
    sh:not [ sh:class ont:AlternativeTitle ] ;
    sh:not [ sh:class ont:Category ] ;
    sh:not [ sh:class ont:Role ] ;
    sh:not [ sh:class ont:Region ] ;
    sh:not [ sh:class ont:TitleType ] .

shape:ContentTypeDisjointShape a sh:NodeShape ;
    sh:targetClass ont:ContentType ;
    sh:name "ContentTypeDisjointShape" ;
    sh:description "A ContentType must not simultaneously belong to any other domain class." ;
    sh:not [ sh:class ont:Title ] ;
    sh:not [ sh:class ont:Talent ] ;
    sh:not [ sh:class ont:Participation ] ;
    sh:not [ sh:class ont:Genre ] ;
    sh:not [ sh:class ont:AlternativeTitle ] ;
    sh:not [ sh:class ont:Category ] ;
    sh:not [ sh:class ont:Role ] ;
    sh:not [ sh:class ont:Region ] ;
    sh:not [ sh:class ont:TitleType ] .

shape:AlternativeTitleDisjointShape a sh:NodeShape ;
    sh:targetClass ont:AlternativeTitle ;
    sh:name "AlternativeTitleDisjointShape" ;
    sh:description "An AlternativeTitle must not simultaneously belong to any other domain class." ;
    sh:not [ sh:class ont:Title ] ;
    sh:not [ sh:class ont:Talent ] ;
    sh:not [ sh:class ont:Participation ] ;
    sh:not [ sh:class ont:Genre ] ;
    sh:not [ sh:class ont:ContentType ] ;
    sh:not [ sh:class ont:Category ] ;
    sh:not [ sh:class ont:Role ] ;
    sh:not [ sh:class ont:Region ] ;
    sh:not [ sh:class ont:TitleType ] .

shape:CategoryDisjointShape a sh:NodeShape ;
    sh:targetClass ont:Category ;
    sh:name "CategoryDisjointShape" ;
